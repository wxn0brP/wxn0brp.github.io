{
	"compilerOptions": {
		"module": "es2022",
		"target": "es2024",
		"moduleResolution": "bundler",
		"paths": {},
		"esModuleInterop": true,
		"skipLibCheck": true,
		"outDir": "./dist",
		"declaration": true,
		"rootDir": "./src",
		"strict": false
	},
	"include": [
		"./src"
	],
	"exclude": [
		"node_modules"
	]
}
